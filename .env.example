# ============================================================
# Event-Driven Trading Signal Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# .env is gitignored — your keys will never be committed.
# ============================================================

# ------ REQUIRED: DeepSeek API (the only paid API) -----------
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-paste-your-real-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ------ OPTIONAL: Telegram Bot (free, for signal alerts) -----
# Skip these if you don't need Telegram notifications.
# Signals will still be saved to SQLite and printed to console.
#
# How to get these values — see docs/setup-guide.md Step 3
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------ Pipeline tunables (defaults are fine for PoC) --------
LLM_MODEL=deepseek-chat
CLASSIFY_MIN_CONFIDENCE=0.4
IMPACT_MIN_CONFIDENCE=0.3
LLM_TIMEOUT=30.0

# ------ Paths (no need to change) ----------------------------
FEEDS_CONFIG=config/feeds.yaml
TICKERS_CONFIG=config/tickers.yaml
DB_PATH=data/signals.db
